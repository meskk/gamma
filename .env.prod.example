# Production environment for compose.prod.yml — copy to .env.prod and fill in.
# .env.prod is UNCOMMITTED (gitignored); never put real secrets in this example.
# Every service in the compose file reads this one file.

# ── Postgres (the postgres service reads POSTGRES_*; the apps read DATABASE_URL) ──
POSTGRES_USER=gamma
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=gamma
# Hostname `postgres` = the compose service name. Keep the password in sync.
DATABASE_URL=postgres://gamma:CHANGE-ME-strong-password@postgres:5432/gamma

# ── Redis (compose-internal) ──
REDIS_URL=redis://redis:6379

# ── Object storage (the bundled MinIO service, or a managed S3 — see OPERATIONS.md) ──
MINIO_ROOT_USER=gamma
MINIO_ROOT_PASSWORD=CHANGE-ME-strong-secret
S3_ENDPOINT=http://minio:9000
S3_REGION=eu-central-1
S3_BUCKET=gamma-media
S3_ACCESS_KEY=gamma
S3_SECRET_KEY=CHANGE-ME-strong-secret

# ── core-api ──
CORE_API_BIND=0.0.0.0:8080
RUST_LOG=info
# The public frontend origin (CORS).
GAMMA_CORS_ORIGIN=https://app.example.com
# TLS terminates in the host reverse proxy, which sets X-Forwarded-For — trust it
# so the per-IP rate limits key on the real client, not the proxy.
GAMMA_TRUST_PROXY=true
# Rate limits ON in prod (these are the defaults; tune deliberately).
# GAMMA_RATE_LIMIT_PER_SECOND=20
# GAMMA_RATE_LIMIT_BURST=100
# GAMMA_RATE_LIMIT_AUTH_BURST=5
# GAMMA_RATE_LIMIT_AUTH_REFILL_SECS=2
# Versioned econ knobs (defaults are built in; mount a TOML to override):
# GAMMA_ECON_PARAMS=/config/econ-params.toml

# ── settlement scheduler ──
# GAMMA_SETTLEMENT_LOOKBACK=3

# ── ingestion worker ──
# Talks to core-api over the compose network.
GAMMA_API_BASE_URL=http://core-api:8080/v1
# The SERVICE account's credentials (role = 'service'; RUNBOOK §2 — the var
# names predate the service role).
GAMMA_OPERATOR_EMAIL=ingestion@example.com
GAMMA_OPERATOR_PASSWORD=CHANGE-ME-service-account-password
# GAMMA_ANALYZER=heuristic
# GAMMA_HEALTH_PORT=8081
