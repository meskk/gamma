# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Local dev defaults match docker-compose.yml.

DATABASE_URL=postgres://gamma:gamma@localhost:5432/gamma
REDIS_URL=redis://localhost:6379

# Object storage (MinIO locally; any S3-compatible store in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=gamma-media
S3_ACCESS_KEY=gamma
S3_SECRET_KEY=gammasecret

# Core API
CORE_API_BIND=0.0.0.0:8080
RUST_LOG=info,core_api=debug
# Path to a versioned econ-params TOML (the economic knobs). Unset = built-in
# defaults (EconParams::default), which is what local dev uses. Point this at a
# committed parameter set to ship tuned economics without a code change (ADR 0003).
# GAMMA_ECON_PARAMS=./econ-params.toml
# Allowed CORS origin for the browser frontend (the Next.js app's origin). Point
# this at the real frontend URL in prod.
GAMMA_CORS_ORIGIN=http://localhost:3000

# Per-IP rate limits (token buckets). Two layers, both disabled by this flag:
# a LOOSE edge backstop over everything and a TIGHT bucket on /v1/auth/* (the
# per-account login throttle is independent and always on). Disable locally —
# the SPA fires several requests per page (doubled by React StrictMode in dev).
GAMMA_RATE_LIMIT_DISABLED=true
# Edge backstop: sustained requests/second and burst per IP.
GAMMA_RATE_LIMIT_PER_SECOND=20
GAMMA_RATE_LIMIT_BURST=100
# Auth bucket: burst, and seconds per replenished attempt (5 quick tries, then
# one every 2s).
GAMMA_RATE_LIMIT_AUTH_BURST=5
GAMMA_RATE_LIMIT_AUTH_REFILL_SECS=2
# Behind a trusted reverse proxy set GAMMA_TRUST_PROXY=true so both buckets key
# on X-Forwarded-For instead of the proxy's own IP.
