  "query": "\n            SELECT id, author_id, category, body, created_at, popularity_score, media_id\n            FROM posts\n            WHERE hidden_at IS NULL AND ($1::bigint IS NULL OR author_id = $1)\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
