{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT c.id, c.post_id, c.author_id, c.body, c.created_at\n            FROM comments c\n            JOIN posts p ON p.id = c.post_id\n            WHERE c.post_id = $1 AND p.hidden_at IS NULL\n            ORDER BY c.created_at ASC\n            LIMIT $2 OFFSET $3\n            ",
