  "query": "\n            INSERT INTO comments (post_id, author_id, body)\n            SELECT $1, $2, $3\n            WHERE EXISTS (SELECT 1 FROM posts WHERE id = $1 AND hidden_at IS NULL)\n            RETURNING id, post_id, author_id, body, created_at\n            ",
