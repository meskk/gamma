# Gamma ingestion service — copy to .env and fill in the operator credentials.
# Defaults target a local `docker compose` stack (Redis) + `cargo run -p core-api`.

REDIS_URL=redis://localhost:6379
GAMMA_INGESTION_QUEUE=gamma:ingestion
GAMMA_API_BASE_URL=http://localhost:8080/v1

# An operator account the write-back authenticates as. Register a user via the API,
# then promote it in dev:  UPDATE users SET role = 'operator' WHERE id = <id>;
GAMMA_OPERATOR_EMAIL=
GAMMA_OPERATOR_PASSWORD=

# Optional knobs (sensible defaults shown).
GAMMA_MODEL_VERSION=heuristic-v0
GAMMA_POLL_TIMEOUT_SECONDS=5
GAMMA_REQUEST_TIMEOUT_SECONDS=10
