# Gamma ingestion service — copy to .env and fill in the operator credentials.
# Defaults target a local `docker compose` stack (Redis) + `cargo run -p core-api`.

REDIS_URL=redis://localhost:6379
GAMMA_INGESTION_QUEUE=gamma:ingestion
# Where posts that still fail after retries are quarantined (defaults to
# "<GAMMA_INGESTION_QUEUE>:dead"). Inspect with `LRANGE`; replay with
# `RPOPLPUSH <dead> <main>` — the consumer normalises the {"post_id":…} JSON entry
# back to an id, so a replay does NOT destroy the entry.
GAMMA_INGESTION_DEAD_QUEUE=gamma:ingestion:dead
# Reliable-queue processing list (defaults to "<GAMMA_INGESTION_QUEUE>:processing").
# Ids popped-but-not-yet-acked live here so a crash mid-post can't lose them; the
# worker re-queues any stragglers at startup. Leave the default unless you run
# multiple workers off one queue and want per-worker processing lists.
GAMMA_INGESTION_PROCESSING_QUEUE=gamma:ingestion:processing
GAMMA_API_BASE_URL=http://localhost:8080/v1

# An operator account the write-back authenticates as. Register a user via the API,
# then promote it in dev:  UPDATE users SET role = 'operator' WHERE id = <id>;
GAMMA_OPERATOR_EMAIL=
GAMMA_OPERATOR_PASSWORD=

# Optional knobs (sensible defaults shown).
# Which analyser to run: 'heuristic' (the deterministic placeholder) or 'model'
# (the real analyser, M2.4c — needs the inference endpoints below; fails fast
# at startup if they are unreachable).
# Each analyser OWNS its model_version intrinsically (the heuristic stamps
# "heuristic-v1"), so there is no separate version knob to set or bump.
GAMMA_ANALYZER=heuristic
# ── GAMMA_ANALYZER=model (M2.4c): OpenAI-kompatible Inference-Endpoints ──
# Judgment-LLM (vLLM) und Embedding-Encoder (TEI); genau EIN Modell je Endpoint —
# model_version wird aus /v1/models der Server abgeleitet (no-knob provenance).
# GAMMA_MODEL_BASE_URL=http://gpu-box:8000
# GAMMA_EMBED_BASE_URL=http://gpu-box:8080   # Default: GAMMA_MODEL_BASE_URL
# GAMMA_TOPIC_LABELS=tech,sport,musik        # das Kategorien-Set der App
# GAMMA_MODEL_TIMEOUT_SECONDS=60
# GAMMA_MODEL_MAX_CHARS=8000                 # Input-Budget beider Calls (< Kontextlimits)
GAMMA_POLL_TIMEOUT_SECONDS=5
GAMMA_REQUEST_TIMEOUT_SECONDS=10
# Retry on transient (network / 5xx) API failures: total attempts (1 = no retry)
# and the exponential-backoff seed in seconds (with full jitter).
GAMMA_RETRY_ATTEMPTS=3
GAMMA_RETRY_BASE_DELAY_SECONDS=0.5

# Liveness endpoint (/healthz) port; 0 disables it. The Dockerfile HEALTHCHECK
# and the compose healthcheck probe this.
# GAMMA_HEALTH_PORT=8081
